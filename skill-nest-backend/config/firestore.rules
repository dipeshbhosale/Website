rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isTeacher() {
      return isAuth() && request.auth.token.role == 'teacher';
    }

    function isStudent() {
      return isAuth() && request.auth.token.role == 'student';
    }

    // ── Users collection ─────────────────────────────────────
    match /users/{userId} {
      // Anyone authenticated can read public profiles
      allow read: if isAuth();
      // Only the owner can write their own document
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // never allow client-side delete
    }

    // ── Courses collection ───────────────────────────────────
    match /courses/{courseId} {
      // Anyone (even unauthenticated) can read courses
      allow read: if true;
      // Only teachers can create
      allow create: if isTeacher();
      // Only the instructor who owns the course can update/delete
      allow update: if isTeacher() && resource.data.instructorId == request.auth.uid;
      allow delete: if isTeacher() && resource.data.instructorId == request.auth.uid;

      // Course ratings subcollection
      match /ratings/{ratingId} {
        allow read: if true;
        allow write: if isStudent() && ratingId == request.auth.uid;
      }
    }

    // ── Enrollments collection ───────────────────────────────
    match /enrollments/{enrollmentId} {
      // Users can only read/write their own enrollments
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Events (Calendar) collection ─────────────────────────
    match /events/{eventId} {
      // Users can only access their own events
      allow read:   if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
  }
}
